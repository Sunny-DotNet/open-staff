{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "Origins": ["http://localhost:3000", "http://localhost:5173"]
  },
  "FileStorage": {
    "ExportPath": "openstaff-exports",
    "TempPath": "temp",
    "MaxFileSize": 104857600
  },
  "Workspaces": {
    "RootPath": "workspaces"
  }
}
