# ============================================================
# OpenStaff Monorepo .gitignore
# ============================================================

# .NET
src/**/bin/
src/**/obj/
src/**/*.user
src/**/*.suo
src/**/.vs/
src/**/*.DotSettings.user
*.DotSettings.user

# Node / Vue
web/node_modules/
web/dist/
web/.vite/
web/*.local
web/.turbo
web/.cache

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
*.sln.ref

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.local
.env.*.local
!.env.example

# Docker
docker-compose.override.yml

# Runtime generated directories (should be ignored)
workspaces/
runtime/

# Logs
*.log
logs/
.playwright-mcp/

# Test results
test-results/
coverage/
*.coverage

# Build artifacts
build/
dist/
*.zip
*.tar.gz

# Database (local development)
*.db
*.db-shm
*.db-wal
!src/**/*.db

# Temporary files
tmp/
temp/
*.tmp
*.temp

# NOTE: src/plugins/ contains important plugin implementations and should NOT be ignored
# NOTE: Only ignore runtime/ generated plugin directories, not source code
