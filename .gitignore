# ============================================================
# OpenStaff Monorepo .gitignore
# ============================================================

# .NET
src/**/bin/
src/**/obj/
src/**/*.user
src/**/*.suo
src/**/.vs/
src/**/*.DotSettings.user
*.DotSettings.user

# Node / Vue
web/node_modules/
web/dist/
web/.vite/
web/*.local
web/.turbo
web/.cache

# IDE
.vs/
.idea/
.vscode/
*.swp
*.swo
*~
*.sln.ref

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.local
.env.*.local
!.env.example

# Docker
docker-compose.override.yml

# Runtime generated directories (should be ignored)
workspaces/
runtime/
!/src/agents/OpenStaff.Agent.Services/Agent/Runtime/
!/src/agents/OpenStaff.Agent.Services/Agent/Runtime/**
!/src/platform/OpenStaff.Agents/Runtime/
!/src/platform/OpenStaff.Agents/Runtime/**

# Logs
*.log
logs/
.playwright-mcp/

# Test results
test-results/
coverage/
*.coverage

# Build artifacts
build/
dist/
*.zip
*.tar.gz

# Database (local development)
*.db
*.db-shm
*.db-wal
!src/**/*.db

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Root-level local audit / review artifacts
/agent-role-*.png
/agent-roles-*.png
/monica-*.png
/mcp-*.png
/overview-dark-*.png
/project-group-chat-*.png
/project-groupchat-*.png
/projects-*.png
/provider-account-*.png
/provider-accounts-*.png
/settings-*.png
/*-network.txt
/*-console.txt
/*requests.txt
/mention-test-before.txt
/workspace-project-*.md
/workspace-verify-*.md
/logo-debug.png
/logo-fixed.png

# Source-tree code snapshot residue
/src/agents/OpenStaff.Agent.Vendor.GitHubCopilot/**/*.txt
/src/plugins/OpenStaff.Plugin.*/Agent/*.txt
/src/plugins/OpenStaff.Plugin.*/Provider/*.txt
/src/providers/OpenStaff.Provider.GitHubCopilot/Provider/**/*.txt
!/src/agents/OpenStaff.Agent.Builtin/Prompts/*.txt

# NOTE: src/plugins/ contains important plugin implementations and should NOT be ignored
# NOTE: Only ignore runtime/ generated plugin directories, not source code
